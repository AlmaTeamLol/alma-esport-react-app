{
  "private": true,
  "workspaces": [
    "backend/**",
    "frontend/**",
    "packages/**"
  ],
  "scripts": {
    "front:dev": "cd frontend && npm run dev",
    "front:build": "cd frontend && npm run build",
    "front:start": "cd frontend && node ./dist/app.js",
    "back:dev": "cd backend && tsx --watch --env-file .env.development src/index.ts",
    "back:build": "cd backend && tsc ./src/index.ts",
    "back:start": "cd backend && node ./dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  }
}
